{
  "name": "RideshareOdoMeter Android Build",
  "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "apt-get update && apt-get install -y wget unzip git && chmod +x setup_android_sdk.sh && ./setup_android_sdk.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-android-tools.android-extension",
        "Kotlin.kotlin"
      ]
    }
  },
  "remoteUser": "root",
  "forwardPorts": [],
  "portsAttributes": {}
}